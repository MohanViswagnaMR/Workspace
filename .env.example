# =====================================================================
#  FIREBASE CONFIGURATION
# ---------------------------------------------------------------------
#  1. Copy this file to ".env"  (cp .env.example .env)
#  2. Paste the values from your Firebase project (see SETUP.md, Step 3)
#  3. Restart the dev server after editing.
#
#  Until these are filled in, the app runs in LOCAL MODE:
#  no login is required and data is saved to this browser's localStorage.
#  As soon as VITE_FIREBASE_API_KEY has a real value, the app switches
#  to cloud mode: a login screen appears and data syncs to Firestore.
#
#  NOTE: Vite only exposes variables that start with "VITE_".
#  These values are PUBLIC by design (they ship in the browser bundle).
#  Your data is protected by Firestore Security Rules, not by hiding keys.
# =====================================================================

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
